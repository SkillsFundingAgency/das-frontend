{
    "$schema": "https://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "storageAccountName": {
            "type": "string",
            "metadata": {
                "description": "Name of the storage account"
            }
        },
        "accessTier": {
            "type": "string",
            "defaultValue": "",
            "allowedValues": [
                "Hot",
                "Cool",
                ""
            ],
            "metadata": {
                "description": "This setting is required if using BlobStorage as the storageKind, otherwise can be left blank"
            }
        },
        "storageKind": {
            "type": "string",
            "defaultValue": "Storage",
            "allowedValues": [
                "Storage",
                "StorageV2",
                "BlobStorage"
            ]
        },
        "afdProfileName": {
            "type": "string",
            "metadata": {
                "description": "Name of Azure Front Door profile"
            }
        },
        "afdEndPointName": {
            "type": "string",
            "metadata": {
                "description": "Name of Azure Front Door endpoint"
            }
        },
        "originHostName": {
            "type": "string"
        },
        "customDomainName": {
            "defaultValue": "",
            "type": "string"
        },
        "customDomainResourceName": {
            "defaultValue": "",
            "type": "string",
            "metadata": {
                "description": "The resource name for the custom domain in Azure"
            }
        },
        "routeName": {
            "type": "string",
            "defaultValue": "default-route",
            "metadata": {
                "description": "The name of the AFD route"
            }
        },
        "originGroupName": {
            "type": "string",
            "defaultValue": "default-origin-group",
            "metadata": {
                "description": "The name of the AFD origin group"
            }
        },
        "originName": {
            "type": "string",
            "defaultValue": "default-origin",
            "metadata": {
                "description": "The name of the AFD origin"
            }
        },
        "isHttpAllowed": {
            "type": "bool",
            "defaultValue": true
        },
        "afdProfileResourceGroup": {
            "type": "string"
        },
        "originPath": {
            "type": "string"
        },
        "enableCors": {
            "type": "string",
            "defaultValue": "False"
        },
        "containerArray": {
            "type": "array"
        },
        "utcValue": {
            "type": "string",
            "defaultValue": "[utcNow()]"
        },
        "minimumTlsVersion": {
            "type": "string",
            "defaultValue": "TLS1_2"
        }
    },
    "variables": {},
    "resources": [
        {
            "apiVersion": "2017-05-10",
            "name": "[concat('storage-account-arm-', parameters('utcValue'))]",
            "type": "Microsoft.Resources/deployments",
            "properties": {
                "mode": "Incremental",
                "templateLink": {
                    "uri": "https://raw.githubusercontent.com/SkillsFundingAgency/das-platform-building-blocks/master/templates/storage-account-arm.json",
                    "contentVersion": "1.0.0.0"
                },
                "parameters": {
                    "storageAccountName": {
                        "value": "[parameters('storageAccountName')]"
                    },
                    "accessTier": {
                        "value": "[parameters('accessTier')]"
                    },
                    "storageKind": {
                        "value": "[parameters('storageKind')]"
                    },
                    "enableCors": {
                        "value": "[parameters('enableCors')]"
                    },
                    "allowBlobPublicAccess": {
                        "value": true
                    },
                    "allowSharedKeyAccess": {
                        "value": true
                    },
                    "minimumTlsVersion": {
                        "value": "[parameters('minimumTlsVersion')]"
                    }
                }
            },
            "dependsOn": []
        },
        {
            "apiVersion": "2017-05-10",
            "name": "[concat('storage-container-', parameters('containerArray')[copyIndex()].name, '-', parameters('utcValue'))]",
            "type": "Microsoft.Resources/deployments",
            "condition": "[greater(length(parameters('containerArray')), 0)]",
            "properties": {
                "mode": "Incremental",
                "templateLink": {
                    "uri": "https://raw.githubusercontent.com/SkillsFundingAgency/das-platform-building-blocks/master/templates/storage-container.json",
                    "contentVersion": "1.0.0.0"
                },
                "parameters": {
                    "storageAccountName": {
                        "value": "[parameters('storageAccountName')]"
                    },
                    "containerName": {
                        "value": "[parameters('containerArray')[copyIndex()].name]"
                    },
                    "publicAccess": {
                        "value": "[parameters('containerArray')[copyIndex()].publicAccess]"
                    }
                }
            },
            "copy": {
                "name": "containercopy",
                "count": "[length(parameters('containerArray'))]"
            },
            "dependsOn": [
                "[concat('storage-account-arm-', parameters('utcValue'))]"
            ]
        },
        {
            "apiVersion": "2017-05-10",
            "name": "[concat('afd-endpoint-', parameters('utcValue'))]",
            "type": "Microsoft.Resources/deployments",
            "resourceGroup": "[parameters('afdProfileResourceGroup')]",
            "properties": {
                "mode": "Incremental",
                "templateLink": {
                    "uri": "https://raw.githubusercontent.com/SkillsFundingAgency/das-platform-building-blocks/master/templates/afd-endpoint.json",
                    "contentVersion": "1.0.0.0"
                },
                "parameters": {
                    "afdProfileName": {
                        "value": "[parameters('afdProfileName')]"
                    },
                    "afdEndPointName": {
                        "value": "[parameters('afdEndPointName')]"
                    },
                    "originHostName": {
                        "value": "[parameters('originHostName')]"
                    },
                    "originPath": {
                        "value": "/frontend"
                    },
                    "customDomainName": {
                        "value": "[parameters('customDomainName')]"
                    },
                    "customDomainResourceName": {
                        "value": "[parameters('customDomainResourceName')]"
                    },
                    "routeName": {
                        "value": "[parameters('routeName')]"
                    },
                    "originGroupName": {
                        "value": "[parameters('originGroupName')]"
                    },
                    "originName": {
                        "value": "[parameters('originName')]"
                    }
                }
            },
            "dependsOn": [
                "[concat('storage-account-arm-', parameters('utcValue'))]"
            ]
        }
    ],
    "outputs": {
        "storageKey": {
            "type": "string",
            "value": "[reference(concat('storage-account-arm-', parameters('utcValue'))).outputs.storageKey.value]"
        },
        "storageConnectionString": {
            "type": "string",
            "value": "[reference(concat('storage-account-arm-', parameters('utcValue'))).outputs.storageConnectionString.value]"
        }
    }
}
